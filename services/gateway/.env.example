# x402 定价（SP1 单居民）
X402_NETWORK=eip155:84532
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
GATEWAY_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
