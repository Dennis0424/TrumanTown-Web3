DEFAULT_COST_PER_THINK=10000
# 批量结算触发（先到先发）
SETTLE_MAX_BATCH=10
SETTLE_MAX_WAIT_MS=60000
# 计划5：以链上 AgentRegistry 为准定价（反伪造）。置 1 启用
GATEWAY_USE_REGISTRY=0
REGISTRY_ADDRESS=0x...
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org
AGENT_IDS=0
REGISTRY_REFRESH_MS=30000
