# x402 facilitator environment — env var names aligned to OviatoHQ/x402-facilitator-hono source
# (examples/node/src/index.ts reads EVM_PRIVATE_KEY, RPC_URL_BASE_SEPOLIA, PORT exactly)
# Confirmed by LIVE smoke test: GET /facilitator/supported, POST /facilitator/verify both respond.

# Base Sepolia RPC (public endpoint OK for dev; own node for high throughput)
# CAIP-2 network identifier used internally: eip155:84532
RPC_URL_BASE_SEPOLIA=https://sepolia.base.org

# Gas/settler key — used by /settle to broadcast EIP-3009 token transfer on-chain.
# /verify does NOT use this key (signature check only, no gas).
# Plan 5 fills a real funded value; anvil default key is a placeholder here.
EVM_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# HTTP port. Default in upstream example is 4020; TrumanTown uses 8403 to avoid conflict.
PORT=8403
